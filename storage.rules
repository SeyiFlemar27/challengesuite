rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function isPdfOrImage() {
      return request.resource.contentType.matches('application/pdf') || isImage();
    }

    match /users/{userId}/submissions/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.auth.uid == userId
        && (isImage() || isVideo())
        && request.resource.size < 100 * 1024 * 1024;
    }

    match /users/{userId}/challenge-media/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.auth.uid == userId
        && (isImage() || isVideo())
        && request.resource.size < 200 * 1024 * 1024;
    }

    match /users/{userId}/identity-documents/{fileName} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if signedIn()
        && request.auth.uid == userId
        && isPdfOrImage()
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
